{
  "name": "personal-website",
  "version": "1.0.0",
  "private": true,
  "description": "Personal Website for Sam Macaluso",
  "keywords": [
    "personal",
    "website"
  ],
  "license": "MIT",
  "author": "Sam Macaluso <sam@macalu.so>",
  "scripts": {
    "build": "gatsby build",
    "clean": "rm -rf public .cache",
    "develop": "gatsby develop",
    "format": "prettier --write \"src/**/*.js\"",
    "serve:build": "npm run clean && npm run build && http-server ./public",
    "start": "npm run develop",
    "start:prod": "npm run build && npm run serve:build",
    "deploy": "npm run clean && npm run build && node ./scripts/deploy",
    "test": "jest"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^1.2.27",
    "@fortawesome/free-brands-svg-icons": "^5.12.1",
    "@fortawesome/free-regular-svg-icons": "^5.12.1",
    "@fortawesome/free-solid-svg-icons": "^5.12.1",
    "@fortawesome/react-fontawesome": "^0.1.9",
    "gatsby": "^2.19.43",
    "gatsby-image": "^2.2.43",
    "gatsby-plugin-google-analytics": "^2.1.37",
    "gatsby-plugin-manifest": "^2.2.47",
    "gatsby-plugin-offline": "^2.2.10",
    "gatsby-plugin-react-helmet": "^3.1.23",
    "gatsby-plugin-sharp": "^2.4.12",
    "gatsby-source-filesystem": "^2.1.55",
    "gatsby-transformer-javascript-frontmatter": "^2.1.25",
    "gatsby-transformer-remark": "^2.6.58",
    "gatsby-transformer-sharp": "^2.3.18",
    "prop-types": "^15.6.2",
    "react": "^16.13.0",
    "react-dom": "^16.13.0",
    "react-helmet": "^5.2.1",
    "react-typography": "^0.16.19",
    "typography": "^0.16.18"
  },
  "devDependencies": {
    "@babel/core": "^7.8.7",
    "babel-core": "^7.0.0-bridge.0",
    "babel-jest": "^23.6.0",
    "babel-preset-gatsby": "^0.1.6",
    "enzyme": "^3.11.0",
    "enzyme-adapter-react-16": "^1.15.2",
    "gatsby-plugin-sass": "^2.1.30",
    "gh-pages": "^2.2.0",
    "http-server": "^0.11.1",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^23.6.0",
    "node-sass": "^4.13.1",
    "prettier": "^1.19.1"
  }
}
